# Base URL for API requests (CloudFront URL in prod, or API Gateway URL directly)
VITE_API_URL=https://<your-domain-or-cloudfront-url>

# Vite dev server proxy target — proxies /api/* to this URL to avoid CORS in local dev
VITE_API_PROXY_TARGET=https://<api-gateway-id>.execute-api.<region>.amazonaws.com

# Show/hide the "Sign in with Google" button (set true once Google OAuth is configured)
VITE_ENABLE_GOOGLE_AUTH=false

# Skip real auth and auto-login as a fake admin user — for frontend-only development
VITE_DEV_BYPASS_AUTH=true
